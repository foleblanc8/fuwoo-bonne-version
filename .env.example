# ─── Coupdemain — Variables d'environnement ───────────────────────────────────
# Copier ce fichier en .env et remplir les valeurs avant de déployer.
# NE JAMAIS committer le fichier .env dans git.

# ── Django ──────────────────────────────────────────────────────────────────
SECRET_KEY=django-insecure-remplace-moi-par-une-vraie-cle-aleatoire
DEBUG=False

# ── Base de données PostgreSQL ───────────────────────────────────────────────
DATABASE_URL=postgres://user:password@localhost:5432/fuwoo_db

# ── Email (choisir Resend OU SendGrid) ──────────────────────────────────────
# Resend (recommandé) : https://resend.com — créer un compte gratuit, vérifier domaine
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# SendGrid (alternatif) : https://sendgrid.com
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx

# Adresse expéditeur (doit correspondre au domaine vérifié)
DEFAULT_FROM_EMAIL=Coupdemain <noreply@coupdemain.ca>

# ── URLs ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=https://coupdemain.ca

# ── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# ── CORS (domaines autorisés en production) ──────────────────────────────────
# CORS_ALLOWED_ORIGINS=https://coupdemain.ca,https://www.coupdemain.ca
